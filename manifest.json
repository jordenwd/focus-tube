{
  "name": "FocusTube",
  "version": "0.1.0",
  "description": "Removes distracting elements from YouTube: Homepage videos, recommended videos, sidebars, shorts, etc.",
  "manifest_version": 3,
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["scripts/content.js"],
      "run_at": "document_end"
    }
  ],
  "host_permissions": ["*://*.youtube.com/*"],
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  }
}
